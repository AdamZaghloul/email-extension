{
  "name": "Email Extensions",
  "description": "Checks if a given email is subscriebd to our mailing list.",
  "version": "1.0",
  "manifest_version": 3,
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Open the extension"
    }
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "index.html",
    "default_icon": "hello_extensions.png"
  }
}