{
  "name": "Email Checker",
  "description": "Checks if a given email is subscribed to our MailerLite mailing list.",
  "version": "1.0",
  "manifest_version": 3,
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Open the extension"
    }
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "index.html",
    "default_icon": "images/icon_128x128.png"
  },
  "icons": {
    "16": "images/icon_16x16.png",
    "32": "images/icon_32x32.png",
    "48": "images/icon_48x48.png",
    "128": "images/icon_128x128.png"
  }
}